            <property name="styleSheet">
             <string notr="true">QPushButton#wrr {
                    background-color: qlineargradient(x1:0, y1:0, x2:1, y2:1, stop:0 #F44336, stop:1 #D32F2F);
                    color: white;
                    border: 2px solid #B71C1C;
                    border-radius: 15px;
                    padding: 10px 20px;
                    font-size: 16pt;
                    font-weight: bold;
                    box-shadow: 3px 3px 10px rgba(0, 0, 0, 0.4);
                  }
                  QPushButton#wrr:hover {
                    background-color: qlineargradient(x1:0, y1:0, x2:1, y2:1, stop:0 #EF5350, stop:1 #E53935);
                    box-shadow: 4px 4px 12px rgba(0, 0, 0, 0.5);
                  }
                  QPushButton#wrr:pressed {
                    background-color: qlineargradient(x1:0, y1:0, x2:1, y2:1, stop:0 #B71C1C, stop:1 #9E1212);
                    border: 2px solid #8E0000;
                    box-shadow: inset 2px 2px 5px rgba(0, 0, 0, 0.4);
                  }
                  QPushButton#wrr:disabled {
                    background-color: #B0B0B0;
                    border: 2px solid #808080;
                    color: #E0E0E0;
                    box-shadow: none;
                  }</string>
